{
  "name": "n8n-nodes-unraid",
  "version": "1.0.1-develop-03",
  "description": "n8n community node for the Unraid API - manage Docker containers, VMs, array and disk health, notifications, and system metrics via GraphQL.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "unraid",
    "unraid-api",
    "docker",
    "vm",
    "virtual-machine",
    "nas",
    "homelab",
    "self-hosted",
    "graphql",
    "automation",
    "server-management",
    "notifications"
  ],
  "license": "MIT",
  "homepage": "https://github.com/lt-kraken/n8n-nodes-unraid",
  "bugs": {
    "url": "https://github.com/lt-kraken/n8n-nodes-unraid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lt-kraken/n8n-nodes-unraid.git"
  },
  "author": {
    "name": "lt-kraken",
    "url": "https://github.com/lt-kraken"
  },
  "engines": {
    "node": ">=22.0"
  },
  "main": "index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && shx cp nodes/Unraid/unraid.svg dist/nodes/Unraid/unraid.svg",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/UnraidApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Unraid/Unraid.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@n8n/node-cli": "*",
    "@types/node": "^25.9.3",
    "eslint": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "jsonc-eslint-parser": "^3.1.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.0.0",
    "shx": "^0.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
